# ============================================================
#  CrowdWisdomTrading — Environment Variables
# ============================================================
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to version control.
# ============================================================

# --- OpenRouter API Key ---
# The LLM provider for all agents.
# Get your free key at: https://openrouter.ai/keys
# It should start with "sk-or-v1-"
OPENROUTER_API_KEY=sk-or-v1-replace-me

# --- Apify API Token ---
# Used by Agent 1 (Market Scout) to scrape Polymarket/Kalshi.
# Get your free token at: https://console.apify.com/account/integrations
# It should start with "apify_api_"
APIFY_API_TOKEN=apify_api_replace-me

# --- Prediction Mode (optional) ---
# "stacked_1min"  → 5 sequential 1-min Kronos predictions combined (default, extra credit)
# "direct_5min"   → single 5-bar Kronos prediction
PREDICTION_MODE=stacked_1min

# --- Log Level (optional) ---
# Set to DEBUG for verbose output, INFO for normal
LOG_LEVEL=INFO
